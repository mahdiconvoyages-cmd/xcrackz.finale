{
    "name": "vite-react-typescript-starter",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:prod": "NODE_ENV=production vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit -p tsconfig.app.json",
        "analyze": "vite build --mode analyze",
        "mobile": "cd mobile && npm start",
        "install:all": "npm install && cd mobile && npm install",
        "clean:all": "rm -rf node_modules mobile/node_modules && npm install && cd mobile && npm install",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mapbox/search-js-react": "^1.3.0",
        "@mui/icons-material": "^7.3.7",
        "@mui/material": "^7.3.7",
        "@sentry/react": "^10.25.0",
        "@supabase/supabase-js": "^2.75.1",
        "@techstark/opencv-js": "^4.12.0-release.1",
        "@tensorflow/tfjs": "^4.22.0",
        "@tensorflow/tfjs-backend-webgl": "^4.22.0",
        "date-fns": "^4.1.0",
        "dynamsoft-capture-vision-router": "^2.4.33",
        "dynamsoft-core": "^3.4.31",
        "dynamsoft-document-normalizer": "^2.6.11",
        "dynamsoft-license": "^3.4.31",
        "expo": "^54.0.19",
        "file-saver": "^2.0.5",
        "framer-motion": "^12.23.24",
        "jspdf": "^3.0.3",
        "jspdf-autotable": "^5.0.2",
        "jszip": "^3.10.1",
        "leaflet": "^1.9.4",
        "lucide-react": "^0.344.0",
        "mapbox-gl": "^3.15.0",
        "node-mailjet": "^6.0.11",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hot-toast": "^2.6.0",
        "react-leaflet": "^5.0.0",
        "react-native": "0.81.5",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-signature-canvas": "^5.0.1",
        "react-native-web": "^0.21.0",
        "react-onesignal": "^3.4.0",
        "react-router-dom": "^7.9.3",
        "react-toastify": "^11.0.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.9.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/file-saver": "^2.0.7",
        "@types/jspdf": "^1.3.3",
        "@types/leaflet": "^1.9.21",
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "@vitest/ui": "^4.0.9",
        "autoprefixer": "^10.4.18",
        "eslint": "^9.9.1",
        "eslint-plugin-react-hooks": "^5.1.0-rc.0",
        "eslint-plugin-react-refresh": "^0.4.11",
        "globals": "^15.9.0",
        "happy-dom": "^20.0.10",
        "jsdom": "^27.2.0",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.5.3",
        "typescript-eslint": "^8.3.0",
        "vite": "^5.4.2",
        "vitest": "^4.0.9"
    }
}
